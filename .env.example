# ── AeroXProtect (axp) environment ──────────────────────────────────────────
# Copy to `.env` and fill in. docker-compose reads this file.

# General
PROJECT_ENV=development            # development => debug + non-secure cookies

# Database (axp-mysql / schema `axp`)
DATABASE_URL=axp-mysql
DATABASE_ID=axp
DATABASE_PW=change-me-db-pass
DATABASE_DB=axp
MYSQL_ROOT_PASSWORD=change-me-root-pass

# Redis (denylist + Celery broker)
REDIS_URL=axp-redis

# Flask
SECRET_KEY=change-me-flask-secret

# JWT
JWT_SECRET=change-me-jwt-secret-use-32+random-bytes
JWT_ACCESS_TTL=900                 # 15m (seconds)
JWT_REFRESH_TTL=1209600            # 14d (seconds)

# Snowflake worker id (MUST differ per service: backend=1, worker=2)
SNOWFLAKE_INSTANCE=1

# Camera credential encryption (Fernet key, base64 urlsafe 32 bytes) — used P1+
# generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENC_KEY=

# go2rtc media hub
GO2RTC_URL=http://axp-go2rtc:1984

# CORS (comma separated; * for dev only)
CORS_ALLOWED_ORIGINS=*

# Error tracking (optional)
SENTRY_DSN=

# Bootstrap first admin (optional — `seed-admin` uses these if set)
BOOTSTRAP_ADMIN_ID=admin
BOOTSTRAP_ADMIN_PW=admin1234!
BOOTSTRAP_ADMIN_NAME=관리자

# Detector
GPU_ENABLED=false
DETECTOR_BIND=0.0.0.0:8099

# Frontend (build-time, injected into Vite)
VITE_APP_API_URL=/api/v1
VITE_APP_NAME=axp
VITE_APP_VERSION=1
